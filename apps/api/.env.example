# ─────────────────────────────────────────────────────────────────
# AgroMarket Bolivia — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/agromarket
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─── Cache ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ─── JWT (use strong random values in production!) ────────────────
JWT_ACCESS_SECRET=CHANGE_ME_minimum_32_characters_long
JWT_REFRESH_SECRET=CHANGE_ME_minimum_32_characters_long_too
JWT_ACCESS_EXPIRY=900        # 15 minutes in seconds
JWT_REFRESH_EXPIRY=2592000   # 30 days in seconds

# ─── Application ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3001
API_URL=http://localhost:3000

# ─── WhatsApp Business API (Meta Cloud API) ───────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=agromarket-verify

# ─── SMS (Twilio) ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ─── Storage (AWS S3 / DigitalOcean Spaces) ──────────────────────
DO_SPACES_ENDPOINT=http://localhost:9000
DO_SPACES_BUCKET=agromarket-files
DO_SPACES_KEY=minioadmin
DO_SPACES_SECRET=minioadmin
DO_SPACES_REGION=nyc3

# ─── Firebase (Push Notifications) ──────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ─── Elasticsearch ───────────────────────────────────────────────
ELASTICSEARCH_NODE=http://localhost:9200

# ─── Payments (BCB QR Bolivia) ────────────────────────────────────
BCB_API_URL=
BCB_API_KEY=
BCB_MERCHANT_ID=

# ─── ML Scoring Microservice ─────────────────────────────────────
SCORING_SERVICE_URL=http://localhost:8000
SCORING_SERVICE_API_KEY=dev-scoring-key

# ─── External APIs ────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
OPENWEATHER_API_KEY=
SENASAG_API_URL=https://api.senasag.gob.bo
