{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@agromarket/types": ["packages/types/src"],
      "@agromarket/database": ["packages/database/src"],
      "@agromarket/ui": ["packages/ui/src"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", "coverage"]
}
